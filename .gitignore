# ============================================================================
# ERP Project - .gitignore
# Security-first: block secrets, IDE files, build artifacts, OS junk
# ============================================================================

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
application-local.yml
application-local.properties
secrets/
credentials/

# --- Maven Build Output ---
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# --- IDE Files ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
nbproject/
nb-dist/
nbactions.xml
nb-configuration.xml

# --- Java ---
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# --- OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Docker ---
.docker/
docker-compose.override.yml

# --- Testcontainers ---
.testcontainers.properties

# --- jqwik database (reproducibility seeds - local only) ---
**/.jqwik-database

# --- Logs ---
*.log
logs/

# --- Temp Files ---
*.tmp
*.swp
*.swo
*~

# --- CI/Test Reports (local only) ---
.ci-report.txt
.test-report.txt
frontend/node_modules/
frontend/dist/
frontend/.angular/
