<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude test code -->
    <Match>
        <Source name="~.*Test\.java"/>
    </Match>
    <Match>
        <Package name="~com\.erp\.test\..*"/>
    </Match>

    <!-- Exclude JPA entities (false positives with field injection) -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <Class name="~.*JpaEntity"/>
            <Class name="~.*Request"/>
            <Class name="~.*Response"/>
        </Or>
    </Match>

    <!-- Exclude Lombok-generated code -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Method name="~(get|set).*"/>
    </Match>
</FindBugsFilter>
